{
  "title": "Menu tree",
  "description": "A JSON representation of a Drupal menu tree",
  "type": "array",
  "items": {"$ref":  "#/$defs/langcode"},
  "$defs": {
    "langcode": {
      "type": "array",
      "properties": {
        "name": {
          "type": "string"
        },
        "langcode": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "external": {
          "type": "boolean"
        },
        "hasItems": {
          "type": "boolean"
        },
        "weight": {
          "type": "integer"
        },
        "sub_tree": {
          "type": "array",
          "items": {"$ref": "#/$defs/tree"}
        }
      },
      "required": ["name", "langcode", "url"]
    },
    "tree": {
      "type": "array",
      "required": ["id", "name", "url"],
      "properties": {
        "description": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "sub_tree": {
          "type": "array",
          "items": {"$ref": "#/$defs/tree"}
        },
        "weight": {
          "type": "integer",
          "default": 0
        }
      }
    }
  }
}
