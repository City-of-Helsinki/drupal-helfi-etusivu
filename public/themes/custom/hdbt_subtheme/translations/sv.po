msgstr "Gatu- och parkprojekt"

msgctxt "Helsinki near you roadworks search"
msgid "See all street and park projects near you"
msgstr "See all street and park projects near you"

msgctxt "Helsinki near you"
msgid "Find information on street and park projects near you."
msgstr "Bekanta dig med gatu- och parkprojekt nära din adress."

msgctxt "Feedback close to you block"
